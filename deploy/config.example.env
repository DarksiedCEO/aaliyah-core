# Deployment configuration for aaliyah-core on Cloud Run.
#
# Copy to deploy/config.env (gitignored) and fill in for a REAL GCP project.
# This file holds NO secrets — only identifiers and Secret Manager secret NAMES.
# The secret VALUES live in Secret Manager; Cloud Run resolves them at runtime.

# --- project / region ---
GCP_PROJECT_ID=your-gcp-project-id
REGION=us-central1
SERVICE_NAME=aaliyah-core

# --- image (Artifact Registry) ---
# Full image ref; deploy/build-and-push.sh tags with the git SHA.
ARTIFACT_REGISTRY_HOST=us-central1-docker.pkg.dev
ARTIFACT_REPO=aaliyah
IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/aaliyah/aaliyah-core:REPLACED_WITH_GIT_SHA

# --- runtime identity + Cloud SQL ---
RUNTIME_SERVICE_ACCOUNT=aaliyah-core-run@your-gcp-project-id.iam.gserviceaccount.com
CLOUDSQL_INSTANCE_CONNECTION_NAME=your-gcp-project-id:us-central1:aaliyah-pg

# --- KMS (envelope encryption) ---
KMS_LOCATION=us-central1
KMS_KEY_RING=aaliyah
KMS_CRYPTO_KEY=aaliyah-credentials

# --- OAuth (mailbox connect) ---
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain/api/auth/google/callback

# --- Secret Manager secret NAMES (values are NOT stored here) ---
SECRET_DATABASE_URL=aaliyah-database-url
SECRET_GOOGLE_CLIENT_ID=aaliyah-google-client-id
SECRET_GOOGLE_CLIENT_SECRET=aaliyah-google-client-secret

# --- Cloud Run sizing ---
CONCURRENCY=1
REQUEST_TIMEOUT_SECONDS=120
CPU=1
MEMORY=512Mi
MIN_INSTANCES=0
MAX_INSTANCES=4
